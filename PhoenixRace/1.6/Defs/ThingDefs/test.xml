<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <JobDef>
        <defName>CL_InstallModule</defName>
        <driverClass>ChezhouLib.ClJobDiver.JobDriver_InstallModule</driverClass>
        <reportString>正在安装模块</reportString>
        <casualInterruptible>true</casualInterruptible>
        <allowOpportunisticPrefix>true</allowOpportunisticPrefix>
        <collideWithPawns>false</collideWithPawns>
    </JobDef>

    <WorkGiverDef>
        <defName>CL_WorkGiver_InstallModule</defName>
        <giverClass>ChezhouLib.ClWorkGiver.WorkGiver_InstallModule</giverClass>
        <workType>Crafting</workType>
        <label>安装模块</label>
        <verb>安装模块</verb>
        <gerund>安装模块中</gerund>
        <priorityInType>50</priorityInType>
        <requiredCapacities>
            <li>Manipulation</li>
        </requiredCapacities>
    </WorkGiverDef>

    <ChezhouLib.LibDef.ClModule ParentName="ResourceBase">
        <defName>ClModule_MoveLvI</defName>
        <label>移速模块</label>
        <description>移速模块，增加1的移速。</description>
        <baseWidth>1</baseWidth>
        <baseHeight>1</baseHeight>
        <color>(0.3, 0.85, 0.55)</color>
        
        <addmaxPower>0</addmaxPower>
        <addPowerYield>-1.0</addPowerYield>

        <graphicData>
            <texPath>Things/Item/Special/AIPersonaCore</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>

        <worker Class="ChezhouLib.ClAppereModdleWorker.AppereModdleWorker_StatOffsets">
            <statOffsets>
                <MoveSpeed>1.0</MoveSpeed>
            </statOffsets>
        </worker>

        <statBases>
            <MaxHitPoints>50</MaxHitPoints>
            <MarketValue>120</MarketValue>
            <Mass>0.2</Mass>
        </statBases>
        <thingCategories>
            <li>Manufactured</li>
        </thingCategories>
    </ChezhouLib.LibDef.ClModule>

</Defs>