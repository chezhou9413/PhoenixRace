<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <JobDef>
        <defName>CL_InstallModule</defName>
        <driverClass>ChezhouLib.ClJobDiver.JobDriver_InstallModule</driverClass>
        <reportString>正在安装模块</reportString>
        <casualInterruptible>true</casualInterruptible>
        <allowOpportunisticPrefix>true</allowOpportunisticPrefix>
        <collideWithPawns>false</collideWithPawns>
    </JobDef>

    <WorkGiverDef>
        <defName>CL_WorkGiver_InstallModule</defName>
        <giverClass>ChezhouLib.ClWorkGiver.WorkGiver_InstallModule</giverClass>
        <workType>Crafting</workType>
        <label>安装模块</label>
        <verb>安装模块</verb>
        <gerund>安装模块中</gerund>
        <priorityInType>50</priorityInType>
        <requiredCapacities>
            <li>Manipulation</li>
        </requiredCapacities>
    </WorkGiverDef>

    <ChezhouLib.LibDef.ClModule ParentName="ResourceBase">
        <defName>ClModule_MoveLvI</defName>
        <label>移速模块</label>
        <description>移速模块，增加1的移速。</description>
        <baseWidth>1</baseWidth>
        <baseHeight>1</baseHeight>
        <color>(0.3, 0.85, 0.55)</color>
        
        <addmaxPower>0</addmaxPower>
        <addPowerYield>-1.0</addPowerYield>

        <graphicData>
            <texPath>Things/Item/Special/AIPersonaCore</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>

        <worker Class="ChezhouLib.ClAppereModdleWorker.AppereModdleWorker_StatOffsets">
            <statOffsets>
                <MoveSpeed>1.0</MoveSpeed>
            </statOffsets>
        </worker>

        <statBases>
            <MaxHitPoints>50</MaxHitPoints>
            <MarketValue>120</MarketValue>
            <Mass>0.2</Mass>
        </statBases>
        <thingCategories>
            <li>Manufactured</li>
        </thingCategories>
    </ChezhouLib.LibDef.ClModule>

    <ChezhouLib.LibDef.ClModule ParentName="ResourceBase">
        <defName>ClModule_HeatSink</defName>
        <label>散热条</label>
        <description>横向散热模块，降低装备过热风险。</description>
        <baseWidth>2</baseWidth>
        <baseHeight>1</baseHeight>
        <color>(0.9, 0.45, 0.2)</color>
        
        <addmaxPower>0</addmaxPower>
        <addPowerYield>-2.0</addPowerYield>

        <graphicData>
            <texPath>Things/Item/Special/AIPersonaCore</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <statBases>
            <MaxHitPoints>80</MaxHitPoints>
            <MarketValue>150</MarketValue>
            <Mass>0.5</Mass>
        </statBases>

        <thingCategories>
            <li>Manufactured</li>
        </thingCategories>
    </ChezhouLib.LibDef.ClModule>

    <ChezhouLib.LibDef.ClModule ParentName="ResourceBase">
        <defName>ClModule_PowerCell</defName>
        <label>能量电池</label>
        <description>纵向能量存储单元，为装备提供持续供能与高额电力上限。</description>
        <baseWidth>1</baseWidth>
        <baseHeight>2</baseHeight>
        <color>(0.3, 0.5, 0.95)</color>
        
        <addmaxPower>500</addmaxPower>
        <addPowerYield>15.0</addPowerYield>

        <graphicData>
            <texPath>Things/Item/Special/AIPersonaCore</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <statBases>
            <MaxHitPoints>60</MaxHitPoints>
            <MarketValue>180</MarketValue>
            <Mass>0.8</Mass>
        </statBases>
        <thingCategories>
            <li>Manufactured</li>
        </thingCategories>
    </ChezhouLib.LibDef.ClModule>

    <ChezhouLib.LibDef.ClModule ParentName="ResourceBase">
        <defName>ClModule_ShieldGen</defName>
        <label>护盾发生器</label>
        <description>中型护盾模块，生成防护力场。维持力场需要消耗大量电力。</description>
        <baseWidth>2</baseWidth>
        <baseHeight>2</baseHeight>
        <color>(0.6, 0.3, 0.9)</color>
        
        <addmaxPower>50</addmaxPower>
        <addPowerYield>-12.0</addPowerYield>

        <graphicData>
            <texPath>Things/Item/Special/AIPersonaCore</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <statBases>
            <MaxHitPoints>120</MaxHitPoints>
            <MarketValue>450</MarketValue>
            <Mass>2.0</Mass>
        </statBases>
        <thingCategories>
            <li>Manufactured</li>
        </thingCategories>
    </ChezhouLib.LibDef.ClModule>

    <ChezhouLib.LibDef.ClModule ParentName="ResourceBase">
        <defName>ClModule_AmmoRail</defName>
        <label>弹药导轨</label>
        <description>长条弹药供给导轨，提升装填速度。</description>
        <baseWidth>3</baseWidth>
        <baseHeight>1</baseHeight>
        <color>(0.85, 0.75, 0.2)</color>
        
        <addmaxPower>0</addmaxPower>
        <addPowerYield>-5.0</addPowerYield>

        <graphicData>
            <texPath>Things/Item/Special/AIPersonaCore</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <statBases>
            <MaxHitPoints>70</MaxHitPoints>
            <MarketValue>300</MarketValue>
            <Mass>1.0</Mass>
        </statBases>
        <thingCategories>
            <li>Manufactured</li>
        </thingCategories>
    </ChezhouLib.LibDef.ClModule>

    <ChezhouLib.LibDef.ClModule ParentName="ResourceBase">
        <defName>ClModule_TacCore</defName>
        <label>战术处理核心</label>
        <description>大型战术计算核心，大幅提升综合作战能力，是耗电大户。</description>
        <baseWidth>3</baseWidth>
        <baseHeight>2</baseHeight>
        <color>(0.95, 0.25, 0.3)</color>
        
        <addmaxPower>100</addmaxPower>
        <addPowerYield>-25.0</addPowerYield>

        <graphicData>
            <texPath>Things/Item/Special/AIPersonaCore</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <statBases>
            <MaxHitPoints>150</MaxHitPoints>
            <MarketValue>800</MarketValue>
            <Mass>3.5</Mass>
        </statBases>
        <thingCategories>
            <li>Manufactured</li>
        </thingCategories>
    </ChezhouLib.LibDef.ClModule>

</Defs>