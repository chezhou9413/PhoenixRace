<?xml version="1.0" encoding="utf-8"?>
<Defs>
    
    <ThingDef Name="PhoenixApparelBase" ParentName="ApparelBase" Abstract="True">
        <thingClass>Apparel</thingClass>
        <comps>
            <li Class="ChezhouLib.comp.ApparelAddBodyAddonCompProperties">
                <targetRaces>
                    <li>PhoenixRace</li>
                </targetRaces>
            </li>
        </comps>
        <recipeMaker>
            <unfinishedThingDef>Phoenix_UnfinishedArmor</unfinishedThingDef>           <!--制作过程中显示的未完成物品-->
            <workSpeedStat>GeneralLaborSpeed</workSpeedStat> <!--受通用劳动速度影响-->
            <workSkill>Crafting</workSkill> <!--工作执行的类别-->
        </recipeMaker>
        <apparel>
            <tags>
                <li>RoyalTier7</li> <!--皇权衣物等级-->
            </tags>
        </apparel>
    </ThingDef>

    <ThingDef Name="PhoenixMechanicArmorBase" ParentName="PhoenixApparelBase" Abstract="True">
        <recipeMaker>
            <effectWorking>Smith</effectWorking> <!--工作执行的特效-->
            <soundWorking>Recipe_Machining</soundWorking> <!--工作执行的声效-->
            <recipeUsers>
                <li>TableMachining</li>
            </recipeUsers>
            <defaultIngredientFilter>
                <categories>
                    <li>Root</li>
                </categories>
                <disallowedThingDefs>                    <!--不让用的材料-->
                    <li>Gold</li>
                    <li>Silver</li>
                    <li>Plasteel</li>
                    <li>Jade</li>
                    <li>Uranium</li>
                    <li MayRequire="Ludeon.RimWorld.Anomaly">Bioferrite</li>
                    <li MayRequire="Ludeon.RimWorld.Odyssey">Obsidian</li>
                </disallowedThingDefs>
            </defaultIngredientFilter>
        </recipeMaker>
    </ThingDef>

    <ThingDef ParentName="PhoenixMechanicArmorBase">
        <defName>Phoenix_Apparel_MechanicArmor</defName>
        <label>凤凰机械师甲</label>
        <tickerType>Normal</tickerType>
        <description>凤凰机械师专用装甲，提供强大的机械辅助能力。</description>
        <recipeMaker>
            <researchPrerequisites>                <!--科技前置-->
                <li>UltraMechtech</li>
                <li>Phoenix_BattleApparelSkill</li>
            </researchPrerequisites>
            <displayPriority>530</displayPriority>            <!--UI显示优先级-->
        </recipeMaker>
        <graphicData>
            <texPath>Things/Pawn/Apparel/Phoenix_Apparel_MechanicArmor/Phoenix_Apparel_MechanicArmor</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>2.0</drawSize>
            <drawOffset>(-0.2,0,0.2)</drawOffset>
        </graphicData>
        <statBases>
            <Mass>12</Mass>            <!--重量-->
            <ArmorRating_Sharp>0.91</ArmorRating_Sharp>            <!--利防-->
            <ArmorRating_Blunt>0.91</ArmorRating_Blunt>            <!--钝防-->
            <ArmorRating_Heat>0.91</ArmorRating_Heat>            <!--热防-->
            <Insulation_Cold>64</Insulation_Cold>            <!--冷温适应-->
            <Insulation_Heat>64</Insulation_Heat>            <!--热温适应-->
            <EquipDelay>5</EquipDelay>            <!--装备时间-->
        </statBases>
        <comps>
            <li Class="ChezhouLib.ClThingComp.ThingCompProperties_AppereModdle">
                <!-- 外观模组列的数量（横向格数） -->
                <Cols>5</Cols>
                <!-- 外观模组行的数量（纵向格数） -->
                <Rows>5</Rows>
                <!-- 初始电力储量 / 启动所需电力 -->
                <initPower>500</initPower>
                <!-- 最大电力储量上限 -->
                <maxPower>1000</maxPower>
                <!-- 每次运作的电力产出量（0 表示不产电，仅消耗） -->
                <PowerYield>0</PowerYield>
            </li>
        </comps>
        <equippedStatOffsets>
            <HackingSpeed>1.5</HackingSpeed>            <!--骇入速度-->
            <HackingStealth>1.5</HackingStealth>            <!--骇入隐蔽-->
            <MechBandwidth>120</MechBandwidth>            <!--带宽-->
            <ShootingAccuracyPawn>-0.5</ShootingAccuracyPawn>            <!--射击准度-->
            <MeleeHitChance>-0.5</MeleeHitChance>            <!--近战命中-->
            <VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.5</VacuumResistance>            <!--真空抗性-->
        </equippedStatOffsets>
        <costList>            <!--消耗材料-->
            <NanostructuringChip>2</NanostructuringChip>            <!--纳米结构芯片-->
            <PowerfocusChip>1</PowerfocusChip>            <!--能量汇聚芯片-->
            <Plasteel>120</Plasteel>            <!--玻璃钢-->
            <ComponentSpacer>8</ComponentSpacer>            <!--高级零部件-->
        </costList>
        <apparel>
            <layers>                <!--装备层-->
                <li>Shell</li>
            </layers>
            <bodyPartGroups>                <!--装备部位-->
                <li>Torso</li>
                <li>Arms</li>
                <li>Legs</li>
            </bodyPartGroups>
            <tags>
                <li>Mechlord</li>
            </tags>
            <wornGraphicPath>Things/Pawn/Apparel/Phoenix_Apparel_MechanicArmor/Phoenix_Apparel_MechanicArmor</wornGraphicPath>
        </apparel>
        <!--tradeability>Sellable</tradeability>
        <tradeTags Inherit="False">
            <li>HiTechArmor</li>
        </tradeTags-->
    </ThingDef>

    <ThingDef Name="PhoenixCombatSuitBase" ParentName="PhoenixApparelBase" Abstract="True">
        <recipeMaker>
            <effectWorking>Smith</effectWorking> <!--工作执行的特效-->
            <soundWorking>Recipe_Machining</soundWorking> <!--工作执行的声效-->
            <recipeUsers>
                <li>TableMachining</li>
            </recipeUsers>
            <defaultIngredientFilter>
                <categories>
                    <li>Root</li>
                </categories>
                <disallowedThingDefs>                    <!--不让用的材料-->
                    <li>Gold</li>
                    <li>Silver</li>
                    <li>Plasteel</li>
                    <li>Jade</li>
                    <li>Uranium</li>
                    <li MayRequire="Ludeon.RimWorld.Anomaly">Bioferrite</li>
                    <li MayRequire="Ludeon.RimWorld.Odyssey">Obsidian</li>
                </disallowedThingDefs>
            </defaultIngredientFilter>
            <researchPrerequisites>                <!--科技前置-->
                <li>Phoenix_BattleApparelSkill</li>
            </researchPrerequisites>
        </recipeMaker>
    </ThingDef>

    <ThingDef ParentName="PhoenixCombatSuitBase">
        <defName>Phoenix_Apparel_TightCombatSuit</defName>
        <label>凤凰紧身作战服</label>
        <description>凤凰紧身作战服</description>
        <recipeMaker>
            <researchPrerequisites>
                <li>ComplexClothing</li>
                <li>Phoenix_BattleApparelSkill</li>
            </researchPrerequisites>
            <displayPriority>205</displayPriority>
        </recipeMaker>
        <graphicData>
            <texPath>Things/Pawn/Apparel/Phoenix_Apparel_TightCombatSuit/Phoenix_Apparel_TightCombatSuit</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>2.0</drawSize>
            <drawOffset>(-0.2,0,0.2)</drawOffset>
        </graphicData>
        <costStuffCount>120</costStuffCount>
        <stuffCategories>
            <li>Fabric</li>
            <li>Leathery</li>
        </stuffCategories>
        <thingCategories>
            <li>ApparelMisc</li>
        </thingCategories>
        <statBases>
            <Mass>4</Mass>            <!--重量-->
            <ArmorRating_Sharp>0.91</ArmorRating_Sharp>            <!--利防-->
            <ArmorRating_Blunt>0.91</ArmorRating_Blunt>            <!--钝防-->
            <ArmorRating_Heat>0.91</ArmorRating_Heat>            <!--热防-->
            <Insulation_Cold>64</Insulation_Cold>            <!--冷温适应-->
            <Insulation_Heat>64</Insulation_Heat>            <!--热温适应-->
            <EquipDelay>1</EquipDelay>            <!--装备时间-->
        </statBases>
        <equippedStatOffsets>
            <HackingSpeed>1.5</HackingSpeed>            <!--骇入速度-->
            <HackingStealth>1.5</HackingStealth>            <!--骇入隐蔽-->
            <ShootingAccuracyPawn>5</ShootingAccuracyPawn>            <!--射击准度-->
            <MeleeHitChance>5</MeleeHitChance>            <!--近战命中-->
            <MoveSpeed>1.5</MoveSpeed>            <!--移动速度-->
        </equippedStatOffsets>
        <apparel>
            <layers>                <!--装备层-->
                <li>OnSkin</li> <!--贴身-->
            </layers>
            <bodyPartGroups>                <!--装备部位-->
                <li>Torso</li>
                <li>Arms</li>
                <li>Legs</li>
            </bodyPartGroups>
            <wornGraphicPath>Things/Pawn/Apparel/Phoenix_Apparel_TightCombatSuit/Phoenix_Apparel_TightCombatSuit</wornGraphicPath>
        </apparel>
    </ThingDef>

</Defs>