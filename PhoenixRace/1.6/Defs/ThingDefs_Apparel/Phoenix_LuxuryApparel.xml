<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <ThingDef Name="PhoenixLuxuryApparelBase" ParentName="PhoenixApparelBase" Abstract="True">
        <recipeMaker>
            <effectWorking>Smith</effectWorking> <!--工作执行的特效-->
            <soundWorking>Recipe_Machining</soundWorking> <!--工作执行的声效-->
            <recipeUsers>
                <li>TableMachining</li>
            </recipeUsers>
            <defaultIngredientFilter>
                <categories>
                    <li>Root</li>
                </categories>
                <disallowedThingDefs>                    <!--不让用的材料-->
                    <li>Gold</li>
                    <li>Silver</li>
                    <li>Plasteel</li>
                    <li>Jade</li>
                    <li>Uranium</li>
                    <li MayRequire="Ludeon.RimWorld.Anomaly">Bioferrite</li>
                    <li MayRequire="Ludeon.RimWorld.Odyssey">Obsidian</li>
                </disallowedThingDefs>
            </defaultIngredientFilter>
            <researchPrerequisites>                <!--科技前置-->
                <li>Phoenix_LuxuryApparelSkill</li>
            </researchPrerequisites>
        </recipeMaker>
    </ThingDef>

    <ThingDef ParentName="PhoenixLuxuryApparelBase">
        <defName>Phoenix_Apparel_AdmiralSuit</defName>
        <label>凤凰舰队指挥官服</label>
        <description>凤凰舰队指挥官服</description>
        <recipeMaker>
            <displayPriority>205</displayPriority>
        </recipeMaker>
        <graphicData>
            <texPath>Things/Pawn/Apparel/Phoenix_Apparel_AdmiralSuit/Phoenix_Apparel_AdmiralSuit</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>2.0</drawSize>
            <drawOffset>(-0.2,0,0.2)</drawOffset>
        </graphicData>
        <costStuffCount>120</costStuffCount>
        <stuffCategories>
            <li>Fabric</li>
            <li>Leathery</li>
        </stuffCategories>
        <thingCategories>
            <li>ApparelMisc</li>
        </thingCategories>
        <statBases>
            <Mass>4</Mass>            <!--重量-->
            <ArmorRating_Sharp>0.19</ArmorRating_Sharp>            <!--利防-->
            <ArmorRating_Blunt>0.19</ArmorRating_Blunt>            <!--钝防-->
            <ArmorRating_Heat>0.19</ArmorRating_Heat>            <!--热防-->
            <Insulation_Cold>64</Insulation_Cold>            <!--冷温适应-->
            <Insulation_Heat>64</Insulation_Heat>            <!--热温适应-->
            <EquipDelay>1</EquipDelay>            <!--装备时间-->
        </statBases>
        <equippedStatOffsets>
            <TradePriceImprovement>0.18</TradePriceImprovement>            <!--交易价格改善-->
            <SocialImpact>0.18</SocialImpact> <!--社交效果-->
            <NegotiationAbility>0.18</NegotiationAbility> <!--谈判能力-->
            <PawnBeauty>0.18</PawnBeauty> <!--魅力-->
        </equippedStatOffsets>
        <apparel>
            <layers>                <!--装备层-->
                <li>Shell</li> <!--外套-->
            </layers>
            <bodyPartGroups>                <!--装备部位-->
                <li>Torso</li>
                <li>Arms</li>
                <li>Legs</li>
            </bodyPartGroups>
            <wornGraphicPath>Things/Pawn/Apparel/Phoenix_Apparel_AdmiralSuit/Phoenix_Apparel_AdmiralSuit</wornGraphicPath>
        </apparel>
    </ThingDef>

</Defs>