<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <BodyDef>
    <defName>PhoenixBody</defName>
    <label>凤凰身体</label>
    <corePart>
      <def>Phoenix_Torso</def>
      <height>Middle</height>
      <depth>Outside</depth>
      <groups>
        <li>Torso</li>
      </groups>
      <parts>

        <!-- ===== 内脏 ===== -->
        <li>
          <def>Phoenix_Ribcage</def>
          <coverage>0.036</coverage>
          <depth>Inside</depth>
          <groups>
            <li>Torso</li>
          </groups>
        </li>
        <li>
          <def>Phoenix_Sternum</def>
          <coverage>0.015</coverage>
          <depth>Inside</depth>
          <groups>
            <li>Torso</li>
          </groups>
        </li>
        <li>
          <def>Phoenix_Pelvis</def>
          <coverage>0.025</coverage>
          <height>Bottom</height>
          <depth>Inside</depth>
          <groups>
            <li>Torso</li>
          </groups>
        </li>
        <li>
          <def>Phoenix_Spine</def>
          <coverage>0.025</coverage>
          <depth>Inside</depth>
          <groups>
            <li>Torso</li>
          </groups>
        </li>
        <li>
          <def>Phoenix_Stomach</def>
          <coverage>0.025</coverage>
          <depth>Inside</depth>
          <groups>
            <li>Torso</li>
          </groups>
        </li>
        <li>
          <def>Phoenix_Heart</def>
          <coverage>0.020</coverage>
          <depth>Inside</depth>
          <groups>
            <li>Torso</li>
          </groups>
        </li>
        <li>
          <def>Phoenix_Lung</def>
          <customLabel>left lung</customLabel>
          <coverage>0.025</coverage>
          <depth>Inside</depth>
          <groups>
            <li>Torso</li>
          </groups>
        </li>
        <li>
          <def>Phoenix_Lung</def>
          <customLabel>right lung</customLabel>
          <coverage>0.025</coverage>
          <depth>Inside</depth>
          <groups>
            <li>Torso</li>
          </groups>
        </li>
        <li>
          <def>Phoenix_Kidney</def>
          <customLabel>left kidney</customLabel>
          <coverage>0.017</coverage>
          <depth>Inside</depth>
          <groups>
            <li>Torso</li>
          </groups>
        </li>
        <li>
          <def>Phoenix_Kidney</def>
          <customLabel>right kidney</customLabel>
          <coverage>0.017</coverage>
          <depth>Inside</depth>
          <groups>
            <li>Torso</li>
          </groups>
        </li>
        <li>
          <def>Phoenix_Liver</def>
          <coverage>0.025</coverage>
          <depth>Inside</depth>
          <groups>
            <li>Torso</li>
          </groups>
        </li>

        <!-- ===== 颈部与头部 ===== -->
        <li>
          <def>Phoenix_Neck</def>
          <coverage>0.075</coverage>
          <height>Top</height>
          <groups>
            <li>Neck</li>
          </groups>
          <parts>
            <li>
              <def>Head</def>
              <coverage>0.80</coverage>
              <groups>
                <li>UpperHead</li>
                <li>FullHead</li>
                <li>HeadAttackTool</li>
              </groups>
              <parts>
                <li>
                  <def>Phoenix_Skull</def>
                  <coverage>0.18</coverage>
                  <depth>Inside</depth>
                  <groups>
                    <li>UpperHead</li>
                    <li>Eyes</li>
                    <li>FullHead</li>
                  </groups>
                  <parts>
                    <li>
                      <def>Phoenix_Brain</def>
                      <coverage>0.8</coverage>
                      <groups>
                        <li>UpperHead</li>
                        <li>Eyes</li>
                        <li>FullHead</li>
                      </groups>
                    </li>
                  </parts>
                </li>
                <li>
                  <def>Phoenix_Eye</def>
                  <customLabel>left eye</customLabel>
                  <coverage>0.07</coverage>
                  <groups>
                    <li>FullHead</li>
                    <li>Eyes</li>
                  </groups>
                  <woundAnchorTag>LeftEye</woundAnchorTag>
                  <flipGraphic>true</flipGraphic>
                  <visibleHediffRots>
                    <li>South</li>
                    <li>West</li>
                  </visibleHediffRots>
                </li>
                <li>
                  <def>Phoenix_Eye</def>
                  <customLabel>right eye</customLabel>
                  <coverage>0.07</coverage>
                  <groups>
                    <li>FullHead</li>
                    <li>Eyes</li>
                  </groups>
                  <woundAnchorTag>RightEye</woundAnchorTag>
                  <visibleHediffRots>
                    <li>South</li>
                    <li>East</li>
                  </visibleHediffRots>
                </li>
                <li>
                  <def>Phoenix_Ear</def>
                  <customLabel>left ear</customLabel>
                  <coverage>0.07</coverage>
                  <flipGraphic>true</flipGraphic>
                  <groups>
                    <li>UpperHead</li>
                    <li>FullHead</li>
                  </groups>
                </li>
                <li>
                  <def>Phoenix_Ear</def>
                  <customLabel>right ear</customLabel>
                  <coverage>0.07</coverage>
                  <groups>
                    <li>UpperHead</li>
                    <li>FullHead</li>
                  </groups>
                </li>
                <li>
                  <def>Phoenix_Nose</def>
                  <coverage>0.10</coverage>
                  <groups>
                    <li>FullHead</li>
                  </groups>
                </li>
                <li>
                  <def>Phoenix_Jaw</def>
                  <coverage>0.15</coverage>
                  <groups>
                    <li>Teeth</li>
                    <li>FullHead</li>
                    <li>Mouth</li>
                  </groups>
                  <parts>
                    <li>
                      <def>Tongue</def>
                      <coverage>0.001</coverage>
                      <depth>Inside</depth>
                      <groups>
                        <li>FullHead</li>
                      </groups>
                    </li>
                  </parts>
                </li>
              </parts>
            </li>
          </parts>
        </li>

        <!-- ===== 左肩与左臂 ===== -->
        <li>
          <def>Phoenix_Shoulder</def>
          <customLabel>left shoulder</customLabel>
          <coverage>0.12</coverage>
          <woundAnchorTag>LeftShoulder</woundAnchorTag>
          <flipGraphic>true</flipGraphic>
          <groups>
            <li>Shoulders</li>
          </groups>
          <parts>
            <li>
              <def>Phoenix_Clavicle</def>
              <customLabel>left clavicle</customLabel>
              <coverage>0.09</coverage>
              <height>Top</height>
              <depth>Inside</depth>
              <flipGraphic>true</flipGraphic>
              <groups>
                <li>Torso</li>
              </groups>
            </li>
            <li>
              <def>Phoenix_Arm</def>
              <customLabel>left arm</customLabel>
              <coverage>0.77</coverage>
              <flipGraphic>true</flipGraphic>
              <groups>
                <li>Arms</li>
              </groups>
              <parts>
                <li>
                  <def>Phoenix_Humerus</def>
                  <customLabel>left humerus</customLabel>
                  <coverage>0.1</coverage>
                  <depth>Inside</depth>
                  <groups>
                    <li>Arms</li>
                  </groups>
                </li>
                <li>
                  <def>Phoenix_Radius</def>
                  <customLabel>left radius</customLabel>
                  <coverage>0.1</coverage>
                  <depth>Inside</depth>
                  <groups>
                    <li>Arms</li>
                  </groups>
                </li>
                <li>
                  <def>Phoenix_Hand</def>
                  <customLabel>left hand</customLabel>
                  <coverage>0.14</coverage>
                  <height>Bottom</height>
                  <flipGraphic>true</flipGraphic>
                  <groups>
                    <li>Hands</li>
                  </groups>
                  <parts>
                    <li>
                      <def>Phoenix_Finger</def>
                      <customLabel>left pinky</customLabel>
                      <coverage>0.06</coverage>
                      <groups><li>Hands</li><li>LeftHand</li></groups>
                    </li>
                    <li>
                      <def>Phoenix_Finger</def>
                      <customLabel>left ring finger</customLabel>
                      <coverage>0.07</coverage>
                      <groups><li>Hands</li><li>LeftHand</li></groups>
                    </li>
                    <li>
                      <def>Phoenix_Finger</def>
                      <customLabel>left middle finger</customLabel>
                      <coverage>0.08</coverage>
                      <groups><li>Hands</li><li>LeftHand</li><li>MiddleFingers</li></groups>
                    </li>
                    <li>
                      <def>Phoenix_Finger</def>
                      <customLabel>left index finger</customLabel>
                      <coverage>0.07</coverage>
                      <groups><li>Hands</li><li>LeftHand</li></groups>
                    </li>
                    <li>
                      <def>Phoenix_Finger</def>
                      <customLabel>left thumb</customLabel>
                      <coverage>0.08</coverage>
                      <groups><li>Hands</li><li>LeftHand</li></groups>
                    </li>
                  </parts>
                </li>
              </parts>
            </li>
          </parts>
        </li>

        <!-- ===== 右肩与右臂 ===== -->
        <li>
          <def>Phoenix_Shoulder</def>
          <customLabel>right shoulder</customLabel>
          <coverage>0.12</coverage>
          <woundAnchorTag>RightShoulder</woundAnchorTag>
          <groups>
            <li>Shoulders</li>
          </groups>
          <parts>
            <li>
              <def>Phoenix_Clavicle</def>
              <customLabel>right clavicle</customLabel>
              <coverage>0.09</coverage>
              <height>Top</height>
              <depth>Inside</depth>
              <groups>
                <li>Torso</li>
              </groups>
            </li>
            <li>
              <def>Phoenix_Arm</def>
              <customLabel>right arm</customLabel>
              <coverage>0.77</coverage>
              <groups>
                <li>Arms</li>
              </groups>
              <parts>
                <li>
                  <def>Phoenix_Humerus</def>
                  <customLabel>right humerus</customLabel>
                  <coverage>0.1</coverage>
                  <depth>Inside</depth>
                  <groups>
                    <li>Arms</li>
                  </groups>
                </li>
                <li>
                  <def>Phoenix_Radius</def>
                  <customLabel>right radius</customLabel>
                  <coverage>0.1</coverage>
                  <depth>Inside</depth>
                  <groups>
                    <li>Arms</li>
                  </groups>
                </li>
                <li>
                  <def>Phoenix_Hand</def>
                  <customLabel>right hand</customLabel>
                  <coverage>0.14</coverage>
                  <height>Bottom</height>
                  <groups>
                    <li>Hands</li>
                  </groups>
                  <parts>
                    <li>
                      <def>Phoenix_Finger</def>
                      <customLabel>right pinky</customLabel>
                      <coverage>0.06</coverage>
                      <groups><li>Hands</li><li>RightHand</li></groups>
                    </li>
                    <li>
                      <def>Phoenix_Finger</def>
                      <customLabel>right ring finger</customLabel>
                      <coverage>0.07</coverage>
                      <groups><li>Hands</li><li>RightHand</li></groups>
                    </li>
                    <li>
                      <def>Phoenix_Finger</def>
                      <customLabel>right middle finger</customLabel>
                      <coverage>0.08</coverage>
                      <groups><li>Hands</li><li>RightHand</li><li>MiddleFingers</li></groups>
                    </li>
                    <li>
                      <def>Phoenix_Finger</def>
                      <customLabel>right index finger</customLabel>
                      <coverage>0.07</coverage>
                      <groups><li>Hands</li><li>RightHand</li></groups>
                    </li>
                    <li>
                      <def>Phoenix_Finger</def>
                      <customLabel>right thumb</customLabel>
                      <coverage>0.08</coverage>
                      <groups><li>Hands</li><li>RightHand</li></groups>
                    </li>
                  </parts>
                </li>
              </parts>
            </li>
          </parts>
        </li>

        <!-- ===== 翅膀 ===== -->
        <!-- 左翼，挂在躯干背部高度 -->
        <li>
          <def>Phoenix_Wing</def>
          <customLabel>left wing</customLabel>
          <coverage>0.10</coverage>
          <height>Top</height>
          <depth>Outside</depth>
          <flipGraphic>true</flipGraphic>
          <groups>
            <li>Phoenix_Wings</li>
          </groups>
          <woundAnchorTag>LeftShoulder</woundAnchorTag>
          <parts>
            <li>
              <def>Phoenix_SecondaryFeathers</def>
              <customLabel>left secondary feathers</customLabel>
              <coverage>0.45</coverage>
              <flipGraphic>true</flipGraphic>
              <groups>
                <li>Phoenix_Wings</li>
              </groups>
            </li>
            <li>
              <def>Phoenix_PrimaryFeathers</def>
              <customLabel>left primary feathers</customLabel>
              <coverage>0.45</coverage>
              <flipGraphic>true</flipGraphic>
              <groups>
                <li>Phoenix_Wings</li>
              </groups>
            </li>
          </parts>
        </li>
        <!-- 右翼 -->
        <li>
          <def>Phoenix_Wing</def>
          <customLabel>right wing</customLabel>
          <coverage>0.10</coverage>
          <height>Top</height>
          <depth>Outside</depth>
          <groups>
            <li>Phoenix_Wings</li>
          </groups>
          <woundAnchorTag>RightShoulder</woundAnchorTag>
          <parts>
            <li>
              <def>Phoenix_SecondaryFeathers</def>
              <customLabel>right secondary feathers</customLabel>
              <coverage>0.45</coverage>
              <groups>
                <li>Phoenix_Wings</li>
              </groups>
            </li>
            <li>
              <def>Phoenix_PrimaryFeathers</def>
              <customLabel>right primary feathers</customLabel>
              <coverage>0.45</coverage>
              <groups>
                <li>Phoenix_Wings</li>
              </groups>
            </li>
          </parts>
        </li>

        <!-- ===== 腰部 ===== -->
        <li>
          <def>Waist</def>
          <coverage>0</coverage>
          <height>Bottom</height>
          <groups>
            <li>Waist</li>
          </groups>
        </li>

        <!-- ===== 左腿 ===== -->
        <li>
          <def>Phoenix_Leg</def>
          <customLabel>left leg</customLabel>
          <coverage>0.14</coverage>
          <height>Bottom</height>
          <groups>
            <li>Legs</li>
          </groups>
          <woundAnchorTag>LeftLeg</woundAnchorTag>
          <flipGraphic>true</flipGraphic>
          <parts>
            <li>
              <def>Phoenix_Femur</def>
              <customLabel>left femur</customLabel>
              <coverage>0.1</coverage>
              <depth>Inside</depth>
              <groups><li>Legs</li></groups>
            </li>
            <li>
              <def>Phoenix_Tibia</def>
              <customLabel>left tibia</customLabel>
              <coverage>0.1</coverage>
              <depth>Inside</depth>
              <groups><li>Legs</li></groups>
            </li>
            <li>
              <def>Phoenix_Foot</def>
              <customLabel>left foot</customLabel>
              <coverage>0.1</coverage>
              <flipGraphic>true</flipGraphic>
              <groups><li>Feet</li></groups>
              <parts>
                <li>
                  <def>Phoenix_Toe</def>
                  <customLabel>left little toe</customLabel>
                  <coverage>0.06</coverage>
                  <groups><li>Feet</li></groups>
                </li>
                <li>
                  <def>Phoenix_Toe</def>
                  <customLabel>left fourth toe</customLabel>
                  <coverage>0.07</coverage>
                  <groups><li>Feet</li></groups>
                </li>
                <li>
                  <def>Phoenix_Toe</def>
                  <customLabel>left middle toe</customLabel>
                  <coverage>0.08</coverage>
                  <groups><li>Feet</li></groups>
                </li>
                <li>
                  <def>Phoenix_Toe</def>
                  <customLabel>left second toe</customLabel>
                  <coverage>0.09</coverage>
                  <groups><li>Feet</li></groups>
                </li>
                <li>
                  <def>Phoenix_Toe</def>
                  <customLabel>left big toe</customLabel>
                  <coverage>0.09</coverage>
                  <groups><li>Feet</li></groups>
                </li>
              </parts>
            </li>
          </parts>
        </li>

        <!-- ===== 右腿 ===== -->
        <li>
          <def>Phoenix_Leg</def>
          <customLabel>right leg</customLabel>
          <coverage>0.14</coverage>
          <height>Bottom</height>
          <groups>
            <li>Legs</li>
          </groups>
          <woundAnchorTag>RightLeg</woundAnchorTag>
          <parts>
            <li>
              <def>Phoenix_Femur</def>
              <customLabel>right femur</customLabel>
              <coverage>0.1</coverage>
              <depth>Inside</depth>
              <groups><li>Legs</li></groups>
            </li>
            <li>
              <def>Phoenix_Tibia</def>
              <customLabel>right tibia</customLabel>
              <coverage>0.1</coverage>
              <depth>Inside</depth>
              <groups><li>Legs</li></groups>
            </li>
            <li>
              <def>Phoenix_Foot</def>
              <customLabel>right foot</customLabel>
              <coverage>0.1</coverage>
              <groups><li>Feet</li></groups>
              <parts>
                <li>
                  <def>Phoenix_Toe</def>
                  <customLabel>right little toe</customLabel>
                  <coverage>0.06</coverage>
                  <groups><li>Feet</li></groups>
                </li>
                <li>
                  <def>Phoenix_Toe</def>
                  <customLabel>right fourth toe</customLabel>
                  <coverage>0.07</coverage>
                  <groups><li>Feet</li></groups>
                </li>
                <li>
                  <def>Phoenix_Toe</def>
                  <customLabel>right middle toe</customLabel>
                  <coverage>0.08</coverage>
                  <groups><li>Feet</li></groups>
                </li>
                <li>
                  <def>Phoenix_Toe</def>
                  <customLabel>right second toe</customLabel>
                  <coverage>0.09</coverage>
                  <groups><li>Feet</li></groups>
                </li>
                <li>
                  <def>Phoenix_Toe</def>
                  <customLabel>right big toe</customLabel>
                  <coverage>0.09</coverage>
                  <groups><li>Feet</li></groups>
                </li>
              </parts>
            </li>
          </parts>
        </li>

      </parts>
    </corePart>
  </BodyDef>
</Defs>