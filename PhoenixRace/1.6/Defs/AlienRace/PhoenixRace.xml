<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <HeadTypeDef ParentName="AverageBase">
        <defName>Phoenix_Head_A</defName>
        <graphicPath>AlienRace/Phoenix/Null/Null</graphicPath>
        <gender>None</gender>
    </HeadTypeDef>

    <AlienRace.ThingDef_AlienRace ParentName="BasePawn">
        <defName>PhoenixRace</defName>
        <label>凤凰</label>
        <description>23333333</description>

        <comps>
            <li Class="ChezhouLib.ClThingComp.ThingCompProperties_RaceFly">
                <flySpeed>5</flySpeed>
                <diagonalSpeed>1.414</diagonalSpeed>
                <drawHeight>4</drawHeight>
                <hoverSize>0.1</hoverSize>
                <hoverSpeed>2.5</hoverSpeed>
                <shadowTexPath>back</shadowTexPath>
                <shadowSize>1.2,1.2,1.2</shadowSize>
                <autoLandingJobDefs>
                    <li>LayDown</li>
                </autoLandingJobDefs>
            </li>
            <li Class="ChezhouLib.ClThingComp.ThingCompProperties_ClClipAnimController"/>
        </comps>

        <alienRace>

            <raceRestriction>
                <onlyUseRaceRestrictedApparel>true</onlyUseRaceRestrictedApparel>
                <blackGeneTags>
                    <li>EyeColor</li>
                </blackGeneTags>
                <blackEndoCategories>
                    <li>Melanin</li>
                </blackEndoCategories>
            </raceRestriction>

            <styleSettings>
                <li>
                    <key>HairDef</key>
                    <value>
                        <hasStyle>true</hasStyle>
                        <styleTagsOverride>
                            <li>Phoenix_Category</li>
                        </styleTagsOverride>
                    </value>
                </li>
                <li>
                    <key>BeardDef</key>
                    <value>
                        <hasStyle>false</hasStyle>
                    </value>
                </li>
                <li>
                    <key>TattooDef</key>
                    <value>
                        <hasStyle>false</hasStyle>
                    </value>
                </li>
            </styleSettings>

            <generalSettings>
                <maleGenderProbability>0</maleGenderProbability>
                <minAgeForAdulthood>18</minAgeForAdulthood>
                <immuneToXenophobia>false</immuneToXenophobia>
                <immuneToAge>false</immuneToAge>
                <humanRecipeImport>true</humanRecipeImport>

                <!-- 禁用部分特质，避免与凤凰设定冲突 -->
                <disallowedTraits>
                    <li>
                        <defName Degree="-1">Beauty</defName>
                    </li>
                    <li>
                        <defName Degree="-2">Beauty</defName>
                    </li>
                    <li>
                        <defName>AnnoyingVoice</defName>
                    </li>
                    <li>
                        <defName>CreepyBreathing</defName>
                    </li>
                    <li>
                        <defName>Nudist</defName>
                    </li>
                    <li>
                        <defName Degree="2">DrugDesire</defName>
                    </li>
                    <li>
                        <defName Degree="1">DrugDesire</defName>
                    </li>
                </disallowedTraits>

                <!-- 生育曲线，凤凰寿命极长，生育窗口宽 -->
                <reproduction>
                    <femaleFertilityAgeFactor>
                        <points>
                            <li>(18, 0)</li>
                            <li>(25, 0.8)</li>
                            <li>(100, 1)</li>
                            <li>(500, 1)</li>
                            <li>(800, 0.5)</li>
                            <li>(1200, 0.1)</li>
                            <li>(1500, 0)</li>
                        </points>
                    </femaleFertilityAgeFactor>
                </reproduction>

                <alienPartGenerator>
                    <customDrawSize>(1, 1)</customDrawSize>
                    <customHeadDrawSize>(1.0, 1.0)</customHeadDrawSize>
                    <customPortraitDrawSize>(1, 1)</customPortraitDrawSize>
                    <headOffsetDirectional>
                        <north>
                            <offset>(0, -0.02)</offset>
                        </north>
                        <south>
                            <offset>(0, -0.02)</offset>
                        </south>
                        <east>
                            <offset>(0, 0)</offset>
                        </east>
                        <west>
                            <offset>(0, 0)</offset>
                        </west>
                    </headOffsetDirectional>

                    <bodyTypes>
                        <li>Female</li>
                    </bodyTypes>

                    <headTypes Inherit="False">
                        <li>Phoenix_Head_A</li>
                    </headTypes>

                    <colorChannels>
                        <li>
                            <name>skin</name>
                            <first Class="ColorGenerator_Options">
                                <options>
                                    <li>
                                        <weight>10</weight>
                                        <only>RGB(255,255,255)</only>
                                    </li>
                                </options>
                            </first>
                        </li>
                        <li>
                            <name>hair</name>
                            <first Class="ColorGenerator_Options">
                                <options>
                                    <!-- 火焰渐变色 -->
                                    <li>
                                        <weight>20</weight>
                                        <min>RGB(255,140,0)</min>
                                        <max>RGB(255,220,80)</max>
                                    </li>
                                    <li>
                                        <weight>15</weight>
                                        <min>RGB(200,50,30)</min>
                                        <max>RGB(255,120,60)</max>
                                    </li>
                                    <li>
                                        <weight>10</weight>
                                        <only>RGB(255,255,200)</only>
                                    </li>
                                    <li>
                                        <weight>5</weight>
                                        <only>RGB(255,255,255)</only>
                                    </li>
                                </options>
                            </first>
                        </li>
                        <li>
                            <name>face</name>
                            <first Class="ColorGenerator_Single">
                                <color>RGB(255,255,255)</color>
                            </first>
                        </li>
                        <li>
                            <name>Horn</name>
                            <first Class="ColorGenerator_Options">
                                <options>
                                    <li>
                                        <weight>10</weight>
                                        <only>RGB(255,255,255)</only>
                                    </li>
                                </options>
                            </first>
                        </li>
                        <li>
                            <name>apparel</name>
                            <first Class="ColorGenerator_Single">
                                <color>RGB(255,255,255)</color>
                            </first>
                        </li>
                    </colorChannels>
                    <bodyAddons>
                        <!-- 头部 -->
                        <li>
                            <name>Phoenix_head</name>
                            <userCustomizable>false</userCustomizable>
                            <path>AlienRace/Phoenix/head/Head</path>
                            <colorChannel>skin</colorChannel>
                            <inFrontOfBody>true</inFrontOfBody>
                            <layerInvert>false</layerInvert>
                            <angle>0</angle>
                            <drawSize>0.8</drawSize>
                            <scaleWithPawnDrawsize>true</scaleWithPawnDrawsize>
                            <defaultOffset>Center</defaultOffset>
                            <alignWithHead>true</alignWithHead>
                            <conditions>
                                <BodyPart>
                                    <bodyPart>Head</bodyPart>
                                </BodyPart>
                                <Posture>
                                    <drawnStanding>true</drawnStanding>
                                    <drawnLaying>true</drawnLaying>
                                    <drawnInBed>true</drawnInBed>
                                </Posture>
                            </conditions>
                            <offsets>
                                <west>
                                    <layerOffset>0.1</layerOffset>
                                    <offset>(0, 0)</offset>
                                </west>
                                <south>
                                    <layerOffset>0.1</layerOffset>
                                    <offset>(0, 0)</offset>
                                </south>
                                <north>
                                    <layerOffset>0.1</layerOffset>
                                    <offset>(0, 0)</offset>
                                </north>
                                <east>
                                    <layerOffset>0.1</layerOffset>
                                    <offset>(0, 0)</offset>
                                </east>
                            </offsets>
                        </li>

                        <!-- 头发前层 -->
                        <li>
                            <name>Phoenix_Hair</name>
                            <userCustomizable>false</userCustomizable>
                            <path>AlienRace/Phoenix/hair/maiden</path>
                            <colorChannel>skin</colorChannel>
                            <inFrontOfBody>true</inFrontOfBody>
                            <layerInvert>false</layerInvert>
                            <angle>0</angle>
                            <drawSize>0.8</drawSize>
                            <scaleWithPawnDrawsize>true</scaleWithPawnDrawsize>
                            <defaultOffset>Center</defaultOffset>
                            <alignWithHead>true</alignWithHead>
                            <conditions>
                                <BodyPart>
                                    <bodyPart>Head</bodyPart>
                                </BodyPart>
                                <Posture>
                                    <drawnStanding>true</drawnStanding>
                                    <drawnLaying>true</drawnLaying>
                                    <drawnInBed>true</drawnInBed>
                                </Posture>
                            </conditions>
                            <offsets>
                                <west>
                                    <layerOffset>0.11</layerOffset>
                                    <offset>(0, 0)</offset>
                                </west>
                                <south>
                                    <layerOffset>0.11</layerOffset>
                                    <offset>(0, 0)</offset>
                                </south>
                                <north>
                                    <layerOffset>0.11</layerOffset>
                                    <offset>(0,0)</offset>
                                </north>
                                <east>
                                    <layerOffset>0.11</layerOffset>
                                    <offset>(0, 0)</offset>
                                </east>
                            </offsets>
                        </li>

                        <!-- 头发后层 -->
                        <li>
                            <name>Phoenix_HairBack</name>
                            <userCustomizable>false</userCustomizable>
                            <linkVariantIndexWithPrevious>true</linkVariantIndexWithPrevious>
                            <path>AlienRace/Phoenix/hairBack/maidenBack</path>
                            <colorChannel>skin</colorChannel>
                            <inFrontOfBody>true</inFrontOfBody>
                            <layerInvert>false</layerInvert>
                            <angle>0</angle>
                            <drawSize>0.8</drawSize>
                            <scaleWithPawnDrawsize>true</scaleWithPawnDrawsize>
                            <defaultOffset>Center</defaultOffset>
                            <alignWithHead>true</alignWithHead>
                            <conditions>
                                <BodyPart>
                                    <bodyPart>Head</bodyPart>
                                </BodyPart>
                                <Posture>
                                    <drawnStanding>true</drawnStanding>
                                    <drawnLaying>true</drawnLaying>
                                    <drawnInBed>true</drawnInBed>
                                </Posture>
                            </conditions>
                            <offsets>
                                <west>
                                    <layerOffset>-0.33</layerOffset>
                                    <offset>(0, 0)</offset>
                                </west>
                                <south>
                                    <layerOffset>-0.33</layerOffset>
                                    <offset>(0, 0)</offset>
                                </south>
                                <north>
                                    <layerOffset>-0.33</layerOffset>
                                    <offset>(0, 0)</offset>
                                </north>
                                <east>
                                    <layerOffset>-0.33</layerOffset>
                                    <offset>(0, 0)</offset>
                                </east>
                            </offsets>
                        </li>

                        <!-- 头冠羽饰 -->
                        <li>
                            <name>Phoenix_plume</name>
                            <userCustomizable>false</userCustomizable>
                            <path>AlienRace/Phoenix/plume/plume</path>
                            <colorChannel>skin</colorChannel>
                            <inFrontOfBody>true</inFrontOfBody>
                            <layerInvert>false</layerInvert>
                            <angle>0</angle>
                            <drawSize>0.8</drawSize>
                            <scaleWithPawnDrawsize>true</scaleWithPawnDrawsize>
                            <defaultOffset>Center</defaultOffset>
                            <alignWithHead>true</alignWithHead>
                            <conditions>
                                <BodyPart>
                                    <bodyPart>Head</bodyPart>
                                </BodyPart>
                                <Posture>
                                    <drawnStanding>true</drawnStanding>
                                    <drawnLaying>true</drawnLaying>
                                    <drawnInBed>true</drawnInBed>
                                </Posture>
                            </conditions>
                            <offsets>
                                <west>
                                    <layerOffset>0.12</layerOffset>
                                    <offset>(0, 0)</offset>
                                </west>
                                <south>
                                    <layerOffset>0.12</layerOffset>
                                    <offset>(0, 0)</offset>
                                </south>
                                <north>
                                    <layerOffset>-0.33</layerOffset>
                                    <offset>(0, 0)</offset>
                                </north>
                                <east>
                                    <layerOffset>0.12</layerOffset>
                                    <offset>(0, 0)</offset>
                                </east>
                            </offsets>
                        </li>
                    </bodyAddons>

                </alienPartGenerator>

                <!-- 关系概率 -->
                <lovinIntervalHoursFromAge>
                    <points>
                        <li>(18, 12)</li>
                        <li>(100, 12)</li>
                        <li>(500, 24)</li>
                        <li>(1000, 48)</li>
                        <li>(2000, 96)</li>
                    </points>
                </lovinIntervalHoursFromAge>

            </generalSettings>

            <graphicPaths>
                <skinShader>Cutout</skinShader>
                <head>
                    <path>AlienRace/Phoenix/Null/Null</path>
                </head>
                <body>
                    <path>AlienRace/Phoenix/body/Naked_Female</path>
                </body>
                <skeleton>Things/Pawn/Humanlike/Bodies/Dessicated/Dessicated_Thin</skeleton>
            </graphicPaths>

            <thoughtSettings>
                <replacerList>
                </replacerList>
                <cannotReceiveThoughts>
                </cannotReceiveThoughts>
                <restrictedThoughts>
                </restrictedThoughts>
            </thoughtSettings>

            <relationSettings>
                <!-- 全雌性种族，禁用恋爱婚姻关系 -->
                <relationChanceModifierLover>0</relationChanceModifierLover>
                <relationChanceModifierExLover>0</relationChanceModifierExLover>
                <relationChanceModifierFiance>0</relationChanceModifierFiance>
                <relationChanceModifierSpouse>0</relationChanceModifierSpouse>
                <relationChanceModifierExSpouse>0</relationChanceModifierExSpouse>
                <!-- 保留亲属关系 -->
                <relationChanceModifierParent>1</relationChanceModifierParent>
                <relationChanceModifierChild>1</relationChanceModifierChild>
                <relationChanceModifierSibling>1</relationChanceModifierSibling>
            </relationSettings>

        </alienRace>

        <statBases>
            <MarketValue>1500</MarketValue>
            <MoveSpeed>5</MoveSpeed>
            <Flammability>0.7</Flammability>
            <CarryingCapacity>150</CarryingCapacity>
            <NegotiationAbility>0.8</NegotiationAbility>
            <MiningYield>1.2</MiningYield>
            <MiningSpeed>1.2</MiningSpeed>
            <PlantHarvestYield>1.2</PlantHarvestYield>
            <PlantWorkSpeed>1.2</PlantWorkSpeed>
            <ButcheryFleshSpeed>1.2</ButcheryFleshSpeed>
            <ButcheryMechanoidSpeed>1.2</ButcheryMechanoidSpeed>
            <ButcheryFleshEfficiency>1.2</ButcheryFleshEfficiency>
            <ButcheryMechanoidEfficiency>1.2</ButcheryMechanoidEfficiency>
            <AnimalGatherSpeed>1.2</AnimalGatherSpeed>
            <AnimalGatherYield>1.2</AnimalGatherYield>
            <ToxicResistance>0.5</ToxicResistance>
            <PainShockThreshold>0.9</PainShockThreshold>
            <InjuryHealingFactor>1.2</InjuryHealingFactor>
            <ComfyTemperatureMin>-20</ComfyTemperatureMin>
            <ComfyTemperatureMax>60</ComfyTemperatureMax>
            <PsychicSensitivity>1.0</PsychicSensitivity>
            <MentalBreakThreshold>0.15</MentalBreakThreshold>
            <GlobalLearningFactor>1.3</GlobalLearningFactor>
            <ImmunityGainSpeed>1.2</ImmunityGainSpeed>
            <EatingSpeed>1.0</EatingSpeed>
            <MeleeHitChance>1.0</MeleeHitChance>
            <MeleeDamageFactor>1.1</MeleeDamageFactor>
            <WorkSpeedGlobal>1.1</WorkSpeedGlobal>
            <ConstructionSpeed>1.1</ConstructionSpeed>
            <ResearchSpeed>1.2</ResearchSpeed>
            <ArmorRating_Heat>0.35</ArmorRating_Heat>
        </statBases>

        <tools>
            <li>
                <label>left fist</label>
                <labelNoLocation>fist</labelNoLocation>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>10</power>
                <cooldownTime>2</cooldownTime>
                <linkedBodyPartsGroup>LeftHand</linkedBodyPartsGroup>
                <surpriseAttack>
                    <extraMeleeDamages>
                        <li>
                            <def>Stun</def>
                            <amount>14</amount>
                        </li>
                    </extraMeleeDamages>
                </surpriseAttack>
            </li>
            <li>
                <label>right fist</label>
                <labelNoLocation>fist</labelNoLocation>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>10</power>
                <cooldownTime>2</cooldownTime>
                <linkedBodyPartsGroup>RightHand</linkedBodyPartsGroup>
                <surpriseAttack>
                    <extraMeleeDamages>
                        <li>
                            <def>Stun</def>
                            <amount>14</amount>
                        </li>
                    </extraMeleeDamages>
                </surpriseAttack>
            </li>
            <li>
                <label>head</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>5</power>
                <cooldownTime>2</cooldownTime>
                <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
                <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
                <chanceFactor>0.2</chanceFactor>
            </li>
            <!-- 翅膀攻击 -->
            <li>
                <label>wings</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>12</power>
                <cooldownTime>2.5</cooldownTime>
                <surpriseAttack>
                    <extraMeleeDamages>
                        <li>
                            <def>Stun</def>
                            <amount>8</amount>
                        </li>
                    </extraMeleeDamages>
                </surpriseAttack>
            </li>
        </tools>

        <race>
            <thinkTreeMain>Humanlike</thinkTreeMain>
            <thinkTreeConstant>HumanlikeConstant</thinkTreeConstant>
            <intelligence>Humanlike</intelligence>
            <renderTree>PhoenixRenderTree</renderTree>
            <bloodDef>Filth_Blood</bloodDef>
            <bloodSmearDef>Filth_BloodSmear</bloodSmearDef>
            <makesFootprints>true</makesFootprints>
            <canBecomeShambler>true</canBecomeShambler>
            <hasUnnaturalCorpse>true</hasUnnaturalCorpse>
            <soundMeleeDodge>Pawn_MeleeDodge</soundMeleeDodge>
            <fleshType>Normal</fleshType>
            <leatherDef>Leather_Human</leatherDef>
            <nameCategory>HumanStandard</nameCategory>
            <nameGenerator>NamerPersonPhoenix</nameGenerator>
            <body>PhoenixBody</body>
            <baseBodySize>2</baseBodySize>
            <baseHealthScale>1.3</baseHealthScale>
            <foodType>OmnivoreHuman</foodType>
            <lifeExpectancy>3000</lifeExpectancy>
            <gestationPeriodDays>30</gestationPeriodDays>
            <meatMarketValue>1</meatMarketValue>
            <manhunterOnDamageChance>0.1</manhunterOnDamageChance>
            <manhunterOnTameFailChance>0.02</manhunterOnTameFailChance>
            <soundCallIntervalRange>2000~5000</soundCallIntervalRange>
            <hediffGiverSets>
                <li>Human</li>
                <li>OrganicStandard</li>
            </hediffGiverSets>

            <litterSizeCurve>
                <points>
                    <li>(0.5, 0)</li>
                    <li>(1, 1)</li>
                    <li>(1.5, 0)</li>
                </points>
            </litterSizeCurve>

            <!-- 生命阶段定义 -->
            <lifeStageAges>
                <!-- 婴儿期：0~3岁 -->
                <li Class="AlienRace.LifeStageAgeAlien">
                    <def>HumanlikeBaby</def>
                    <minAge>0</minAge>
                    <customDrawSize>(0.75, 0.75)</customDrawSize>
                    <customHeadDrawSize>(0.75, 0.75)</customHeadDrawSize>
                    <customPortraitDrawSize>(0.75, 0.75)</customPortraitDrawSize>
                    <customPortraitHeadDrawSize>(0.75, 0.75)</customPortraitHeadDrawSize>
                </li>
                <!-- 幼年期：3~13岁 -->
                <li Class="AlienRace.LifeStageAgeAlien">
                    <def>HumanlikeChild</def>
                    <minAge>3</minAge>
                    <customDrawSize>(0.8, 0.8)</customDrawSize>
                    <customHeadDrawSize>(0.8, 0.8)</customHeadDrawSize>
                    <customPortraitDrawSize>(0.8, 0.8)</customPortraitDrawSize>
                    <customPortraitHeadDrawSize>(0.8, 0.8)</customPortraitHeadDrawSize>
                </li>
                <!-- 青少年期：13~18岁 -->
                <li Class="AlienRace.LifeStageAgeAlien">
                    <def>HumanlikeTeenager</def>
                    <minAge>13</minAge>
                    <customDrawSize>(0.9, 0.9)</customDrawSize>
                    <customHeadDrawSize>(0.9, 0.9)</customHeadDrawSize>
                    <customPortraitDrawSize>(0.9, 0.9)</customPortraitDrawSize>
                    <customPortraitHeadDrawSize>(0.9, 0.9)</customPortraitHeadDrawSize>
                </li>
                <!-- 成年期：18岁起，寿命3000年 -->
                <li Class="AlienRace.LifeStageAgeAlien">
                    <def>HumanlikeAdult</def>
                    <minAge>18</minAge>
                    <customDrawSize>(1.15, 1.15)</customDrawSize>
                    <customHeadDrawSize>(1.15, 1.15)</customHeadDrawSize>
                    <customPortraitDrawSize>(1.15, 1.15)</customPortraitDrawSize>
                    <customPortraitHeadDrawSize>(1.15, 1.15)</customPortraitHeadDrawSize>
                </li>
            </lifeStageAges>

            <!-- 年龄生成曲线：集中在150~600岁生成，符合长寿种族的正态分布 -->
            <ageGenerationCurve>
                <points>
                    <li>(18, 0)</li>
                    <li>(50, 10)</li>
                    <li>(150, 80)</li>
                    <li>(300, 100)</li>
                    <li>(600, 80)</li>
                    <li>(1000, 30)</li>
                    <li>(1500, 10)</li>
                    <li>(2500, 2)</li>
                    <li>(3000, 0)</li>
                </points>
            </ageGenerationCurve>

        </race>

    </AlienRace.ThingDef_AlienRace>
</Defs>