<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <HediffDef>
        <defName>Hediff_DisruptionMatrix</defName>
        <label>干扰矩阵</label>
        <description>受到电磁干扰影响，移动速度和操作能力降低。</description>
        <hediffClass>HediffWithComps</hediffClass>
        <defaultLabelColor>(0.6, 0.8, 1.0)</defaultLabelColor>
        <isBad>true</isBad>
        <initialSeverity>1.0</initialSeverity>
        <maxSeverity>1.0</maxSeverity>
        <comps>
            <!-- 持续时间：10秒 (600 ticks) -->
            <li Class="HediffCompProperties_Disappears">
                <disappearsAfterTicks>600</disappearsAfterTicks>
                <showRemainingTime>true</showRemainingTime>
            </li>
            <li Class="PhoenixRaceLib.Comp.HediffCompProperties_DisruptionMatrixOverlay"/>
            <li Class="PhoenixRaceLib.Comp.HediffCompProperties_DisableAttackAndAbilities"/>
        </comps>
        <stages>
            <li>
                <label>干扰矩阵</label>
                <overrideLabel>干扰矩阵</overrideLabel>
            </li>
        </stages>
    </HediffDef>
</Defs>