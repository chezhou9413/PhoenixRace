<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <ChezhouLib.LibDef.ClAnimationClipDef>
        <defName>PhoenixFly</defName>
        <label>凤凰族飞行动画</label>
        <raceDef>PhoenixRace</raceDef>
        <priority>1</priority>
        <duration>60</duration>
        <loop>true</loop>
        <loopMode>Loop</loopMode>

        <hediff>
            <li>ClHediff_Flying</li>
        </hediff>

        <!-- 播放的时候隐藏哪个渲染节点 -->
        <hideNodes>
            <li>Phoenix wing front</li>
        </hideNodes>

        <tracks>
            <li>
                <renderNodeName>Phoenix wing back</renderNodeName>
                <texPath>AlienRace/PhoenixAnimation/PhoenixFly/Fly</texPath>
                <frameSpeed>3</frameSpeed>
                <keyframes>
                    <li>
                        <tick>0</tick>
                        <scale>1.5</scale>
                    </li>
                </keyframes>
            </li>
        </tracks>
    </ChezhouLib.LibDef.ClAnimationClipDef>
</Defs>